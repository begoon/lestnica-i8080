                    ; Busy-wait delay. Entry at delay_bc uses caller's BC;
                    ; entry at delay_preset preloads BC=3001h.
                    ; Iterations ≈ (initial BC − 00FFh). At ~1.78 MHz, BC=3001h ≈ 150 ms.
018C:               delay_preset:                                   ; offset=018Ch
018C: 01 01 30              lxi  b, 3001h
