01A2: 23                    inx  h
01A3: 36 55                 mvi  m, 55h          ; slot+2: 'U' glyph
01A5: 23                    inx  h
01A6: 36 1A                 mvi  m, 1Ah          ; slot+3: type = empty
01A8: 23                    inx  h
01A9: 7D                    mov  a, l
01AA: 91                    sub  c
