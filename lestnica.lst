0100:                       org  0100h
                            section lestnica

=F803               monitor_cin      equ 0F803h     ; read char from keyboard
=F809               monitor_cout     equ 0F809h     ; print char to screen
=F815               monitor_hexb     equ 0F815h     ; print byte in hex
=F818               monitor_puts     equ 0F818h     ; print zero-terminated string
=F81B               monitor_scan_kbd equ 0F81Bh     ; scan keyboard (non-blocking)
=F821               monitor_curc     equ 0F821h     ; char under cursor
=F86C               monitor_prompt   equ 0F86Ch     ; monitor prompt (warm start)

=76D0               video_memory     equ 76D0h      ; start of video memory
=004E               video_width      equ 78         ; screen width in chars
=001E               video_height     equ 30         ; screen height in rows

=0809               prng_state       equ 0809h      ; 32-bit PRNG state (D:E at +0/+1, H:L at +2/+3)

                    ; Tile glyphs (RK86 char codes). Cross-referenced with the Z80 port at
                    ; https://github.com/imsushka/TangNano20K-VIDEO/blob/main/soft/LESTNICA.asm
=0009               CHR_PLAYER       equ 09h        ; flower glyph -- the player
=000B               CHR_MUSHROOM     equ 0Bh        ; up-arrow glyph -- kills on contact
=001E               CHR_APPLE        equ 1Eh        ; "pleasant thing" -- +90 BCD points
=0055               CHR_STONEHOLDER  equ 55h        ; 'U' -- spawns falling stones
=004F               CHR_STONE        equ 4Fh        ; 'O' -- boulder; kills on contact
=002A               CHR_STONEKILL    equ 2Ah        ; '*' -- stone-kill splat
=0048               CHR_LAD          equ 48h        ; 'H' -- ladder (climb with up-arrow)
=002E               CHR_JOKER        equ 2Eh        ; '.' -- random-direction trap; 50% jump 2
=0024               CHR_EXIT         equ 24h        ; '$' -- level exit (awards time bonus)
=0023               CHR_BRICK        equ 23h        ; '#' -- solid wall
=002D               CHR_BRIDGE       equ 2Dh        ; '-' -- horizontal bridge
=003D               CHR_FLOOR        equ 3Dh        ; '=' -- horizontal floor

                    ; Movement / arrow-key codes (as returned by the RK86 monitor)
=0008               ARROW_LEFT       equ 08h        ; left arrow
=0018               ARROW_RIGHT      equ 18h        ; right arrow
=0019               ARROW_UP         equ 19h        ; up arrow
=001A               ARROW_DOWN       equ 1Ah        ; down arrow
=0010               ARROW_INVERSE    equ 10h        ; ARROW_LEFT XOR ARROW_RIGHT (used to flip direction)
=0020               KEY_JUMP         equ 20h        ; Space -- sets jump flag in var_key
=0080               KEY_JUMP_FLAG    equ 80h        ; bit 7 of var_key = "jump queued"

